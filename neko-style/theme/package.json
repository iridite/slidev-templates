{
  "name": "slidev-theme-neko-style",
  "version": "1.0.0",
  "description": "A modern Slidev theme with animated glow backgrounds, semantic color system, and 20+ presentation components",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iridite/slidev-templates",
    "directory": "neko-style/theme"
  },
  "keywords": ["slidev-theme", "slidev", "presentation", "glow", "animation", "dark-theme"],
  "files": [
    "components/",
    "layouts/",
    "styles/",
    "setup/",
    "utils/",
    "global-bottom.vue",
    "package.json",
    "README.md"
  ],
  "engines": {
    "slidev": ">=0.49.0"
  },
  "slidev": {
    "colorSchema": "dark",
    "defaults": {
      "fonts": {
        "sans": "Inter, system-ui, sans-serif"
      }
    }
  },
  "dependencies": {
    "@slidev/types": "^0.49.0",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.8",
    "@iconify-json/logos": "^1.2.4"
  },
  "optionalDependencies": {
    "@nolebase/ui-asciinema": "^2.6.0",
    "@tresjs/cientos": "^4.0.2",
    "@tresjs/core": "^4.3.0",
    "@vueuse/motion": "^2.2.6",
    "asciinema-player": "^3.8.0",
    "three": "^0.171.0"
  }
}
